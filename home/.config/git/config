[user]
	name = shiomiyan
	email = 35842766+shiomiyan@users.noreply.github.com
	signingkey = "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIEaYKfWmRpj//39xyJNj/WRTCp14HVhiHf2fNuQH5TDz"
[gpg]
	format = ssh
[gpg "ssh"]
	allowedsignersfile = ~/.ssh/allowed_signers
[commit]
	gpgsign = true
[ui "color"]
	ui = always
[color]
	ui = true
[core]
	autocrlf = input
	editor = nvim -d
	quotepath = false
	symlinks = true
[alias]
	c = commit
	s = status
	gone = ! "git fetch -p && git for-each-ref --format '%(refname:short) %(upstream:track)' | awk '$2 == \"[gone]\" {print $1}' | xargs -r git branch -D"
	force-reset = ! "git reset --hard && git clean -fdx"
[merge]
	tool = nvim -d
[push]
	autoSetupRemote = true
[diff]
	algorithm = patience
	compactionHeuristic = true
[include]
	path = ubsecure.gitconfig
	path = wsl.gitconfig

