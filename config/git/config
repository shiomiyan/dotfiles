	email = 35842766+shiomiyan@users.noreply.github.com
	signingkey = "30B3D66B945D4F401B63338C0D24BF6D3FBDACB0"
[gpg]
	format = openpgp
[commit]
	gpgsign = true
[ui "color"]
	ui = always
[color]
	ui = true
[core]
	autocrlf = input
	editor = nvim -d
	quotepath = false
	symlinks = true
[alias]
	c = commit
	s = status
	gone = ! "git fetch -p && git for-each-ref --format '%(refname:short) %(upstream:track)' | awk '$2 == \"[gone]\" {print $1}' | xargs -r git branch -D"
	force-reset = ! "git reset --hard && git clean -fdx"
[merge]
	tool = nvim -d
[push]
	autoSetupRemote = true
[ghq]
	root = ~/repositories
[diff]
	algorithm = patience
	compactionHeuristic = true
[include]
	path = local.gitconfig
	path = wsl.gitconfig

