# Local workspace state
.agents/
.codex/
.direnv/

# Nix build outputs
result
result-*

# Runtime state produced by managed tools
config/nvim/undo/*
!config/nvim/undo/.gitkeep
config/obsidian/.obsidian/
config/obsidian/*.vault/

# Generated by git-hooks.nix
.pre-commit-config.yaml

# Environment and secret files
.env
.env.*
!.envrc
!.env.example

# Editor and OS files
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Logs and temporary files
*.log
*.tmp
*.temp
